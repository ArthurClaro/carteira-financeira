# Normaliza fim de linha para LF no repositório (evita quebrar scripts shell no
# container Linux e mantém consistência entre Windows/Linux).
* text=auto eol=lf

# Scripts e configs que DEVEM ser LF
*.sh          text eol=lf
Dockerfile    text eol=lf
*.conf        text eol=lf

# Diffs mais legíveis
*.blade.php   diff=html
*.css         diff=css
*.html        diff=html
*.md          diff=markdown
*.php         diff=php

# Excluídos de exports (git archive)
/.github        export-ignore
.editorconfig   export-ignore
.gitattributes  export-ignore

# Binários (não normalizar)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
